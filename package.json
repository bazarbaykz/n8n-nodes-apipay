{
  "name": "n8n-nodes-apipay",
  "version": "0.1.0",
  "description": "n8n community node for ApiPay.kz — Kaspi Pay payment gateway integration",
  "license": "MIT",
  "homepage": "https://apipay.kz",
  "author": {
    "name": "ApiPay",
    "email": "support@apipay.kz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bazarbaykz/n8n-nodes-apipay.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "kaspi",
    "kaspi-pay",
    "apipay",
    "payment-gateway",
    "kazakhstan",
    "invoice",
    "webhook"
  ],
  "main": "index.js",
  "files": [

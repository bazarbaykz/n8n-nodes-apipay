      "dist/credentials/ApiPayApi.credentials.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.24.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "nock": "^13.0.0"
  },
